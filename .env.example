# Telegram Bot Settings
BOT_TOKEN=your_bot_token_here
BOT_NAME=your_bot_name_here

# Database Settings (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/your_db
DB_USERNAME=admin
DB_PASSWORD=secret_password

# Proxy Settings (Optional: leave empty if you use system-wide VPN)
PROXY_HOST=
PROXY_PORT=

# Monitoring
GRAFANA_PASSWORD=admin_password

# Path to the browser profile (cookies, sessions, etc.).
# If left empty, data will be stored in ./data/browser_profile within the project directory.
# To use a custom location, provide an absolute path (e.g., /home/user/dns_profiles).
DNS_REAL_PROFILE_PATH=